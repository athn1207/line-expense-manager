# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# スプレッドシート（高精度領収書の Receipts シート用）
SPREADSHEET_ID=
RECEIPT_SHEET_NAME=Receipts

# ユーザー管理スプレッドシート（user_db）
# A列: userId, B列: spreadsheetId, C列: spreadsheetUrl, D列: createdAt
USER_DB_SPREADSHEET_ID=
USER_DB_SHEET_NAME=user_db

# OpenAI (領収書解析)
OPENAI_API_KEY=

# Google Sheets
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Google Cloud Vision API（領収書画像OCR）
# プロジェクト内のJSONファイル名、または絶対パスを指定
# 例: ./sheets-writer-489221-48f56507cbb3.json
GOOGLE_APPLICATION_CREDENTIALS=
